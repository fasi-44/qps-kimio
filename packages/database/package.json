{
  "name": "@nabh/database",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:verify-formulas": "tsx verify-formulas.ts",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force && prisma db push --accept-data-loss && tsx prisma/seed/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.7",
    "prisma": "^7.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "xlsx": "^0.18.5"
  }
}
